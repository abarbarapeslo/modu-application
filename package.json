{
  "name": "modo",
  "version": "1.0.0",
  "private": true,
  "description": "MODO — Cognitive Digital Twin Platform",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "dev": "docker compose up -d && concurrently -n backend,frontend -c blue,green \"npm run dev -w @modo/backend\" \"npm run dev -w @modo/frontend\"",
    "dev:backend": "npm run dev -w @modo/backend",
    "dev:frontend": "npm run dev -w @modo/frontend",
    "build": "npm run db:generate && npm run build -w @modo/frontend",
    "install:all": "npm install",
    "db:generate": "npm run db:generate -w @modo/backend",
    "db:push": "npm run db:push -w @modo/backend",
    "db:migrate": "npm run db:migrate -w @modo/backend",
    "db:seed": "npm run db:seed -w @modo/backend",
    "db:studio": "npm exec -w @modo/backend prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "dotenv-cli": "^8.0.0"
  }
}
